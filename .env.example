# Local PostgreSQL
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kat_platform?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/kat_platform?schema=public"

# Neon (recommended for production) — use the POOLER URL for DATABASE_URL,
# the DIRECT (non-pooler) URL for DIRECT_URL.
# pgbouncer=true is required on the pooler URL; connect_timeout avoids cold-start failures.
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30&pgbouncer=true"
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"
REDIS_URL=""
REDIS_MESSAGES_CHANNEL="kat:messages:events"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Code execution (Glot.io). Sign up at https://glot.io and copy your API token from account settings.
GLOT_API_TOKEN=""
NEXT_PUBLIC_ENABLE_SW_DEV="false"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Google OAuth (optional — enables "Continue with Google" on login/register pages)
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED="false"
DEFAULT_ORGANIZATION_CODE="KAT-ORG"
DEFAULT_ORGANIZATION_NAME="KAT Academy"
DEFAULT_ORGANIZATION_DOMAIN="kat.africa"

PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxx"
PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxx"

ZOHO_MEETING_API_ROOT="https://meeting.zoho.com/api/v2"
ZOHO_MEETING_JOIN_BASE_URL="https://meet.zoho.com"
ZOHO_MEETING_TIMEZONE="Africa/Lagos"
ZOHO_MEETING_ACCESS_TOKEN=""
ZOHO_MEETING_REFRESH_TOKEN=""
ZOHO_OAUTH_CLIENT_ID=""
ZOHO_OAUTH_CLIENT_SECRET=""
ZOHO_ACCOUNTS_BASE_URL="https://accounts.zoho.com"
ZOHO_OAUTH_REDIRECT_URI="http://localhost:3000/api/integrations/zoho/callback"
ZOHO_MEETING_OAUTH_SCOPES="ZohoMeeting.manageOrg.READ,ZohoMeeting.meeting.CREATE,ZohoMeeting.recording.READ"
ZOHO_MEETING_ZSOID=""
ZOHO_MEETING_PRESENTER_ID=""

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Cron secret — used to authenticate the monthly parent digest endpoint.
# Generate with: openssl rand -hex 32
# Trigger: POST /api/cron/parent-digest  Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# Optional: defaults to "KAT Academy <SMTP_USER>"
SMTP_FROM=""
